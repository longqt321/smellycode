```gitignore
# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Compiled and build artifacts
*.o
*.obj
*.out
*.so
*.dll
*.exe

# Dependencies
.venv/
venv/
env/
.env
.env.local
*.env.*

# Logs and temporary files
*.log
*.tmp
*.swp
*.swo

# Coverage reports
.coverage
htmlcov/
coverage/

# Editors
.vscode/
.idea/

# OS generated files
.DS_Store
Thumbs.db
```